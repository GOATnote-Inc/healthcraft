{
  "name": "ed-decision-rules",
  "version": "0.1.0",
  "displayName": "ED Decision Rules",
  "description": "Apply validated emergency-medicine decision rules (HEART, Wells PE/DVT, qSOFA, CURB-65, Ottawa Ankle/Knee, Canadian C-Spine, PECARN Head CT, NEXUS C-Spine, Alvarado, Centor, Ottawa SAH) to a FHIR Bundle. LLM-driven variable extraction; deterministic scoring.",
  "publisher": "GOATnote / HEALTHCRAFT",
  "license": "Apache-2.0",
  "homepage": "https://github.com/GOATnote-Inc/healthcraft",
  "transport": {
    "type": "mcp",
    "entrypoint": "python -m healthcraft.agents_assemble.superpower_decision_rules"
  },
  "sharp": {
    "envelope": "v1",
    "consumes": ["FHIR.R4.Bundle"],
    "produces": ["DecisionRule.Result"],
    "propagates": ["contextId", "correlationId", "bundleSha256"]
  },
  "tools": [
    {
      "name": "applyDecisionRule",
      "description": "Score a clinical decision rule from a FHIR Bundle. Extracts variables with an LLM (deterministic fallback), then runs HEALTHCRAFT's validated rule library.",
      "inputs": {
        "type": "object",
        "properties": {
          "ruleName": {
            "type": "string",
            "description": "Display name of the decision rule (e.g. 'HEART Score').",
            "examples": [
              "HEART Score",
              "Wells Criteria for PE",
              "qSOFA",
              "CURB-65",
              "Ottawa Ankle Rules",
              "Canadian C-Spine Rule",
              "PECARN Head CT",
              "Alvarado Score",
              "Ottawa SAH Rule"
            ]
          },
          "bundle": {
            "type": "object",
            "description": "FHIR R4 Bundle (or referenced via SHARP bundleUri)."
          },
          "bundleUri": {
            "type": "string",
            "description": "Optional FHIR Bundle URI; the host fetches and inlines."
          },
          "variables": {
            "type": "object",
            "description": "Caller-supplied variable overrides. Skip extraction for any variable supplied here."
          },
          "contextId": {"type": "string"},
          "correlationId": {"type": "string"}
        },
        "required": ["ruleName"]
      },
      "outputs": {
        "type": "object",
        "properties": {
          "sharp": {"type": "object"},
          "data": {
            "type": "object",
            "properties": {
              "rule": {"type": "string"},
              "result": {
                "type": "object",
                "properties": {
                  "score": {"type": "number"},
                  "max_score": {"type": "number"},
                  "risk_level": {"type": "string"},
                  "recommendation": {"type": "string"},
                  "variables_used": {"type": "object"}
                }
              },
              "extraction": {
                "type": "object",
                "properties": {
                  "method": {"type": "string", "enum": ["llm", "deterministic"]},
                  "rationale": {"type": "object"},
                  "missing": {"type": "array", "items": {"type": "string"}},
                  "supplied": {"type": "array", "items": {"type": "string"}}
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "getProtocolDetails",
      "description": "Retrieve a clinical protocol (e.g. STEMI activation, sepsis bundle) by name or ID.",
      "inputs": {
        "type": "object",
        "properties": {
          "protocol_id": {"type": "string"},
          "protocol_name": {"type": "string"}
        }
      }
    },
    {
      "name": "getReferenceArticle",
      "description": "Retrieve a drug monograph, dosing reference, or guideline article.",
      "inputs": {
        "type": "object",
        "properties": {
          "article_id": {"type": "string"},
          "title": {"type": "string"}
        }
      }
    }
  ],
  "evidence": {
    "rubric": "HEALTHCRAFT v10 binary-criteria rubric (Corecraft Eq. 1)",
    "tests": "tests/test_agents_assemble/test_smoke.py",
    "deterministic": true
  }
}
