# Keep the Vercel function bundle small: only ship what the MCP server
# actually loads at runtime (src/healthcraft + configs/agents_assemble +
# the minimal world/protocol configs the world seeder reads).

.venv/
.git/
__pycache__/
**/__pycache__/
.pytest_cache/
.ruff_cache/
results/
evals/
data/
docs/
scripts/
scripts-output/
system-prompts/
tests/
docker/

# Drop heavy task / rubric YAML the streamable MCP server doesn't read.
configs/tasks/
configs/rubrics/
configs/schemas/

# Drop the agent-triage / cds-hooks paths that the streamable MCP entrypoint
# doesn't import; keep superpower_decision_rules + coverage + sharp.
src/healthcraft/agents_assemble/demo/
