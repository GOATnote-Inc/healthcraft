{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GOATnote-Inc/healthcraft/configs/schemas/task.schema.json",
  "title": "HEALTHCRAFT Task Definition",
  "description": "Schema for HEALTHCRAFT task YAML files. Tasks use binary criteria (Corecraft Eq. 1) as the primary evaluation mechanism.",
  "type": "object",
  "required": ["id", "category", "level", "title", "description", "criteria"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]{2,4}-\\d{3}$",
      "description": "Unique task identifier (e.g., CR-001, TR-001, SCJ-002)"
    },
    "category": {
      "type": "string",
      "enum": [
        "information_retrieval",
        "clinical_communication",
        "clinical_reasoning",
        "multi_step_workflows",
        "temporal_reasoning",
        "safety_critical_judgment"
      ],
      "description": "Task category determining evaluation focus"
    },
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Difficulty level (1=Triage, 2=Workup, 3=Treatment, 4=Resuscitation, 5=Mass Casualty)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable task title"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Detailed narrative description of the clinical scenario"
    },
    "system_prompt_override": {
      "type": ["string", "null"],
      "description": "Override the base system prompt for this task. Null uses the default."
    },
    "setting": {
      "type": "object",
      "description": "World state context for the scenario",
      "properties": {
        "facility": {
          "type": "string",
          "description": "Name of the facility"
        },
        "time": {
          "type": "string",
          "format": "date-time",
          "description": "Scenario start time in ISO 8601 format"
        },
        "world_seed": {
          "type": "integer",
          "description": "Deterministic seed for world state generation"
        },
        "department": {
          "type": "string"
        },
        "census": {
          "type": "integer",
          "minimum": 0,
          "description": "Current patient census"
        },
        "beds_available": {
          "type": "integer",
          "minimum": 0
        },
        "active_encounters": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Encounter IDs active at scenario start"
        }
      }
    },
    "patient": {
      "type": "object",
      "description": "Patient demographics, presentation, and clinical data",
      "properties": {
        "age": {
          "type": "integer",
          "minimum": 0,
          "maximum": 120
        },
        "sex": {
          "type": "string",
          "enum": ["M", "F", "X"]
        },
        "chief_complaint": {"type": "string"},
        "arrival_mode": {"type": "string"},
        "esi_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "allergies": {
          "type": "array",
          "items": {
            "oneOf": [
              {"type": "string"},
              {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "reaction": {"type": "string"},
                  "severity": {"type": "string"}
                },
                "required": ["name"]
              }
            ]
          }
        },
        "medications": {
          "type": "array",
          "items": {"type": "string"}
        },
        "past_medical_history": {
          "type": "array",
          "items": {"type": "string"}
        },
        "vitals": {
          "type": "object",
          "properties": {
            "heart_rate": {"type": "integer", "minimum": 0, "maximum": 300},
            "blood_pressure": {"type": "string"},
            "blood_pressure_right": {"type": "string"},
            "blood_pressure_left": {"type": "string"},
            "respiratory_rate": {
              "oneOf": [
                {"type": "integer", "minimum": 0, "maximum": 60},
                {"type": "string"}
              ]
            },
            "spo2": {"type": "integer", "minimum": 0, "maximum": 100},
            "temperature": {"type": "number"},
            "gcs": {"type": "integer", "minimum": 3, "maximum": 15},
            "pain_scale": {
              "oneOf": [
                {"type": "integer", "minimum": 0, "maximum": 10},
                {"type": "string"}
              ]
            }
          }
        },
        "patients": {
          "type": "array",
          "description": "For multi-patient scenarios",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "age": {"type": "integer"},
              "sex": {"type": "string"},
              "chief_complaint": {"type": "string"}
            }
          }
        }
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "description": "Binary evaluation criteria (Corecraft Eq. 1). Each criterion is satisfied (1) or not (0).",
      "items": {
        "$ref": "#/$defs/criterion"
      }
    },
    "expected_tools": {
      "type": "array",
      "items": {"type": "string"},
      "description": "List of MCP tool names the agent is expected to use"
    },
    "expected_sequence": {
      "type": "array",
      "description": "Ordered list of expected steps (documentation, not used for scoring)",
      "items": {
        "type": "object",
        "required": ["step", "action"],
        "properties": {
          "step": {"type": "integer", "minimum": 1},
          "action": {"type": "string"},
          "tools": {"type": "array", "items": {"type": "string"}},
          "critical": {"type": "boolean"},
          "reasoning": {"type": "string"},
          "safety": {"type": "string"},
          "detail": {"type": "string"},
          "time_limit_minutes": {"type": "integer", "minimum": 1}
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional task metadata for indexing and analysis",
      "properties": {
        "confusion_pair": {"type": "string"},
        "openem_condition": {"type": "string"},
        "expected_tool_calls": {"type": "string"},
        "entity_types": {"type": "integer"},
        "time_pressure": {
          "type": "string",
          "enum": ["low", "moderate", "high", "extreme"]
        },
        "cognitive_load": {
          "type": "string",
          "enum": ["low", "moderate", "high", "extreme"]
        },
        "teaching_point": {"type": "string"},
        "no_single_correct_answer": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "criterion": {
      "type": "object",
      "required": ["id", "assertion", "verification"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]{2,4}-\\d{3}-C\\d{2}$",
          "description": "Criterion identifier (e.g., CR-001-C01)"
        },
        "assertion": {
          "type": "string",
          "minLength": 5,
          "description": "What the agent must (or must not) do. Binary: true or false."
        },
        "dimension": {
          "type": "string",
          "enum": [
            "clinical_completeness",
            "clinical_correctness",
            "protocol_adherence",
            "documentation_quality",
            "safety",
            "temporal_sequencing"
          ],
          "description": "Which analytical dimension this criterion belongs to"
        },
        "verification": {
          "type": "string",
          "enum": ["world_state", "llm_judge", "pattern"],
          "description": "How this criterion is verified"
        },
        "check": {
          "type": "string",
          "description": "Verification directive (audit log query for world_state, regex for pattern)"
        },
        "safety_critical": {
          "type": "boolean",
          "default": false,
          "description": "If true, violation zeroes the reward (safety gate)"
        }
      }
    }
  }
}
