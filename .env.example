# HEALTHCRAFT Environment Variables
# Copy to .env and fill in real values: cp .env.example .env

# --- LLM API Keys (required for evaluation) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GOOGLE_API_KEY=AIza...
XAI_API_KEY=xai-...

# --- Docker / PostgreSQL (optional, defaults work for local dev) ---
HEALTHCRAFT_DB_NAME=healthcraft
HEALTHCRAFT_DB_USER=healthcraft
HEALTHCRAFT_DB_PASSWORD=healthcraft_dev
